generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  SELLER

  @@map("user_role")
}

enum AccountStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED

  @@map("account_status")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("product_status")
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  PREORDER

  @@map("stock_status")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED

  @@map("order_status")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  AWAITING_VERIFICATION

  @@map("payment_status")
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  CASH_ON_DELIVERY

  @@map("payment_method")
}

enum NotificationType {
  ORDER
  PAYMENT
  REVIEW
  STOCK
  PROMOTION
  SYSTEM

  @@map("notification_type")
}

enum BannerType {
  HERO
  PROMOTION
  CATEGORY
  FLASH_DEAL

  @@map("banner_type")
}

enum DiscountType {
  PERCENTAGE
  FIXED

  @@map("discount_type")
}

enum DiscountScope {
  ORDER
  PRODUCT
  CATEGORY

  @@map("discount_scope")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("review_status")
}

enum ShipmentStatus {
  PENDING
  PACKED
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED

  @@map("shipment_status")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED

  @@map("payout_status")
}

model SupportedCurrency {
  code      String   @id @db.Char(3)
  name      String   @db.VarChar(64)
  symbol    String   @db.VarChar(8)
  decimals  Int      @default(2) @map("decimals")
  isActive  Boolean  @default(true) @map("is_active")
  isBase    Boolean  @default(false) @map("is_base")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  profiles             UserProfile[]
  sellerPayouts        SellerPayout[]
  carts                Cart[]
  cartItems            CartItem[]
  orders               Order[]
  orderItems           OrderItem[]
  payments             Payment[]
  currencyRatesAsBase  CurrencyRate[] @relation("CurrencyRateBase")
  currencyRatesAsQuote CurrencyRate[] @relation("CurrencyRateTarget")

  @@map("supported_currencies")
}

model User {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String        @unique @db.Citext
  passwordHash    String        @map("password_hash")
  role            UserRole      @default(CUSTOMER)
  status          AccountStatus @default(ACTIVE)
  phone           String?       @db.VarChar(32)
  emailVerifiedAt DateTime?     @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?     @map("last_login_at") @db.Timestamptz(6)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  profile                   UserProfile?
  admin                     Admin?
  seller                    Seller?
  approvedSellers           Seller[]                 @relation("SellerApprovedBy")
  sessions                  UserSession[]
  emailVerificationTokens   EmailVerificationToken[]
  passwordResetTokens       PasswordResetToken[]
  otpCodes                  OtpCode[]
  carts                     Cart[]
  savedCartItems            SavedCartItem[]
  wishlists                 Wishlist[]
  compareLists              CompareList[]
  addresses                 Address[]
  createdCoupons            Coupon[]                 @relation("CouponCreatedBy")
  orders                    Order[]                  @relation("OrderCustomer")
  orderStatusHistory        OrderStatusHistory[]
  paymentProofUploads       PaymentProof[]           @relation("PaymentProofUploadedBy")
  paymentProofVerifications PaymentProof[]           @relation("PaymentProofVerifiedBy")
  couponUsages              CouponUsage[]
  reviews                   Review[]
  notifications             Notification[]
  homepageSectionsUpdated   HomepageSection[]
  inventoryLogs             InventoryLog[]
  siteSettingsUpdated       SiteSetting[]
  auditLogs                 AuditLog[]

  @@index([role, status])
  @@map("users")
}

model UserProfile {
  userId                      String        @id @map("user_id") @db.Uuid
  firstName                   String?       @map("first_name") @db.VarChar(100)
  lastName                    String?       @map("last_name") @db.VarChar(100)
  avatarUrl                   String?       @map("avatar_url")
  dateOfBirth                 DateTime?     @map("date_of_birth") @db.Date
  preferredCurrency           String        @default("LKR") @map("preferred_currency") @db.Char(3)
  preferredLanguage           String        @default("en") @map("preferred_language") @db.VarChar(10)
  themePreference             String        @default("system") @map("theme_preference") @db.VarChar(10)
  preferredPaymentMethod      PaymentMethod @default(CARD) @map("preferred_payment_method")
  preferredShippingMethodCode String        @default("STANDARD") @map("preferred_shipping_method_code") @db.VarChar(50)
  notificationPreferences     Json          @default("{\"email\":true,\"sms\":false,\"push\":true}") @map("notification_preferences")
  createdAt                   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency                SupportedCurrency @relation(fields: [preferredCurrency], references: [code])
  preferredShippingMethod ShippingMethod    @relation("UserProfilePreferredShippingMethod", fields: [preferredShippingMethodCode], references: [code])

  @@map("user_profiles")
}

model Admin {
  userId          String   @id @map("user_id") @db.Uuid
  canManageAdmins Boolean  @default(false) @map("can_manage_admins")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Seller {
  userId         String        @id @map("user_id") @db.Uuid
  storeName      String        @map("store_name") @db.VarChar(160)
  storeSlug      String        @unique @map("store_slug") @db.VarChar(180)
  status         AccountStatus @default(PENDING)
  supportEmail   String?       @map("support_email") @db.Citext
  supportPhone   String?       @map("support_phone") @db.VarChar(32)
  commissionRate Decimal       @default(10) @map("commission_rate") @db.Decimal(5, 2)
  taxId          String?       @map("tax_id") @db.VarChar(100)
  description    String?
  logoUrl        String?       @map("logo_url")
  bannerUrl      String?       @map("banner_url")
  approvedBy     String?       @map("approved_by") @db.Uuid
  approvedAt     DateTime?     @map("approved_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver       User?                 @relation("SellerApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  payoutAccounts SellerPayoutAccount[]
  payouts        SellerPayout[]
  products       Product[]
  orderItems     OrderItem[]

  @@index([status])
  @@map("sellers")
}

model SellerPayoutAccount {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId      String   @map("seller_id") @db.Uuid
  bankName      String   @map("bank_name") @db.VarChar(120)
  accountName   String   @map("account_name") @db.VarChar(180)
  accountNumber String   @map("account_number") @db.VarChar(100)
  branchName    String?  @map("branch_name") @db.VarChar(120)
  swiftCode     String?  @map("swift_code") @db.VarChar(32)
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  seller Seller @relation(fields: [sellerId], references: [userId], onDelete: Cascade)

  @@map("seller_payout_accounts")
}

model SellerPayout {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId     String       @map("seller_id") @db.Uuid
  amount       Decimal      @db.Decimal(14, 2)
  currencyCode String       @map("currency_code") @db.Char(3)
  status       PayoutStatus @default(PENDING)
  periodStart  DateTime?    @map("period_start") @db.Date
  periodEnd    DateTime?    @map("period_end") @db.Date
  paidAt       DateTime?    @map("paid_at") @db.Timestamptz(6)
  reference    String?      @db.VarChar(120)
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)

  seller   Seller            @relation(fields: [sellerId], references: [userId], onDelete: Cascade)
  currency SupportedCurrency @relation(fields: [currencyCode], references: [code])

  @@map("seller_payouts")
}

model UserSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.Inet
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model OtpCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  email      String?   @db.Citext
  purpose    String    @db.VarChar(50)
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

model Category {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @unique @db.VarChar(140)
  slug           String   @unique @db.VarChar(160)
  description    String?
  imageUrl       String?  @map("image_url")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  seoTitle       String?  @map("seo_title") @db.VarChar(180)
  seoDescription String?  @map("seo_description") @db.VarChar(320)
  seoKeywords    String[] @map("seo_keywords")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  subcategories Subcategory[]
  products      Product[]
  coupons       Coupon[]      @relation("CouponCategory")

  @@map("categories")
}

model Subcategory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  name           String   @db.VarChar(140)
  slug           String   @unique @db.VarChar(160)
  description    String?
  imageUrl       String?  @map("image_url")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  seoTitle       String?  @map("seo_title") @db.VarChar(180)
  seoDescription String?  @map("seo_description") @db.VarChar(320)
  seoKeywords    String[] @map("seo_keywords")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, name])
  @@map("subcategories")
}

model Brand {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(160)
  slug        String   @unique @db.VarChar(180)
  logoUrl     String?  @map("logo_url")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  products Product[]

  @@map("brands")
}

model ProductTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(80)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  mappings ProductTagMap[]

  @@map("product_tags")
}

model Product {
  id                 String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId           String?                  @map("seller_id") @db.Uuid
  categoryId         String                   @map("category_id") @db.Uuid
  subcategoryId      String?                  @map("subcategory_id") @db.Uuid
  brandId            String?                  @map("brand_id") @db.Uuid
  name               String                   @db.VarChar(220)
  slug               String                   @unique @db.VarChar(250)
  shortDescription   String?                  @map("short_description") @db.VarChar(500)
  description        String?
  sku                String                   @unique @db.VarChar(120)
  status             ProductStatus            @default(DRAFT)
  stockStatus        StockStatus              @default(IN_STOCK) @map("stock_status")
  currentPrice       Decimal                  @map("current_price") @db.Decimal(14, 2)
  oldPrice           Decimal?                 @map("old_price") @db.Decimal(14, 2)
  discountPercentage Decimal                  @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  stockQuantity      Int                      @default(0) @map("stock_quantity")
  minStockLevel      Int                      @default(5) @map("min_stock_level")
  totalSold          Int                      @default(0) @map("total_sold")
  averageRating      Decimal                  @default(0) @map("average_rating") @db.Decimal(3, 2)
  popularityScore    Decimal                  @default(0) @map("popularity_score") @db.Decimal(10, 2)
  weightKg           Decimal?                 @map("weight_kg") @db.Decimal(10, 3)
  dimensions         Json?
  featured           Boolean                  @default(false)
  trending           Boolean                  @default(false)
  bestSeller         Boolean                  @default(false) @map("best_seller")
  newArrival         Boolean                  @default(false) @map("new_arrival")
  hasVariants        Boolean                  @default(false) @map("has_variants")
  optionalVideoUrl   String?                  @map("optional_video_url")
  seoTitle           String?                  @map("seo_title") @db.VarChar(180)
  seoDescription     String?                  @map("seo_description") @db.VarChar(320)
  seoKeywords        String[]                 @map("seo_keywords")
  metadata           Json                     @default("{}")
  publishedAt        DateTime?                @map("published_at") @db.Timestamptz(6)
  searchVector       Unsupported("tsvector")  @default(dbgenerated()) @map("search_vector")
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)

  seller             Seller?                 @relation(fields: [sellerId], references: [userId], onDelete: SetNull)
  category           Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory        Subcategory?            @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  brand              Brand?                  @relation(fields: [brandId], references: [id], onDelete: SetNull)
  images             ProductImage[]
  videos             ProductVideo[]
  attributeValues    ProductAttributeValue[]
  variants           ProductVariant[]
  tags               ProductTagMap[]
  cartItems          CartItem[]
  savedCartItems     SavedCartItem[]
  wishlistItems      WishlistItem[]
  compareItems       CompareItem[]
  couponAsApplicable Coupon[]                @relation("CouponProduct")
  orderItems         OrderItem[]
  reviews            Review[]
  inventoryLogs      InventoryLog[]

  @@index([categoryId, subcategoryId, status])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  imageUrl  String   @map("image_url")
  altText   String?  @map("alt_text") @db.VarChar(180)
  sortOrder Int      @default(0) @map("sort_order")
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVideo {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  videoUrl  String   @map("video_url")
  provider  String?  @db.VarChar(60)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_videos")
}

model ProductAttribute {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(120)
  inputType  String   @default("select") @map("input_type") @db.VarChar(40)
  isRequired Boolean  @default(false) @map("is_required")
  isVariant  Boolean  @default(false) @map("is_variant")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  attributeValues        ProductAttributeValue[]
  variantAttributeValues ProductVariantAttributeValue[]

  @@map("product_attributes")
}

model ProductAttributeValue {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  attributeId String   @map("attribute_id") @db.Uuid
  value       String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId, value])
  @@map("product_attribute_values")
}

model ProductVariant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  sku           String   @unique @db.VarChar(120)
  name          String?  @db.VarChar(180)
  options       Json     @default("{}")
  price         Decimal  @db.Decimal(14, 2)
  oldPrice      Decimal? @map("old_price") @db.Decimal(14, 2)
  stockQuantity Int      @default(0) @map("stock_quantity")
  weightKg      Decimal? @map("weight_kg") @db.Decimal(10, 3)
  imageUrl      String?  @map("image_url")
  isDefault     Boolean  @default(false) @map("is_default")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  product                Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems              CartItem[]
  savedCartItems         SavedCartItem[]
  orderItems             OrderItem[]
  inventoryLogs          InventoryLog[]
  variantAttributeValues ProductVariantAttributeValue[]

  @@map("product_variants")
}

model ProductVariantAttributeValue {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId   String   @map("variant_id") @db.Uuid
  attributeId String   @map("attribute_id") @db.Uuid
  value       String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  variant   ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeId])
  @@map("product_variant_attribute_values")
}

model ProductTagMap {
  productId String   @map("product_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tag_map")
}

model Cart {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?   @unique @map("user_id") @db.Uuid
  guestToken   String?   @unique @map("guest_token") @db.VarChar(120)
  currencyCode String    @default("LKR") @map("currency_code") @db.Char(3)
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user     User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency SupportedCurrency @relation(fields: [currencyCode], references: [code])
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId       String   @map("cart_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  variantId    String?  @map("variant_id") @db.Uuid
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(14, 2)
  currencyCode String   @map("currency_code") @db.Char(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
